<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form_inherit_cash_journal" model="ir.ui.view">
        <field name="name">account.payment.register.form.cash.journal</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <div class="text-muted">
                    Cash journals are available in the Journal field for cash payment registration.
                </div>
            </xpath>
        </field>
    </record>
</odoo>
