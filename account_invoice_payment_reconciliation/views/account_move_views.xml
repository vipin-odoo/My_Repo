<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_reconcile_registered_payments" model="ir.ui.view">
        <field name="name">account.move.form.reconcile.registered.payments</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_reconcile_registered_payments"
                    type="object"
                    string="Reconcile Payment"
                    class="btn-secondary"
                    invisible="move_type not in ('out_invoice', 'in_invoice', 'out_refund', 'in_refund') or state != 'posted' or payment_state == 'paid'"
                />
            </xpath>
        </field>
    </record>
</odoo>
