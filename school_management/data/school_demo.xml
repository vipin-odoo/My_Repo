<odoo>
    <record id="teacher_jane" model="school.teacher">
        <field name="name">Jane Parker</field>
        <field name="subject">Mathematics</field>
        <field name="email">jane.parker@example.com</field>
    </record>

    <record id="course_math_101" model="school.course">
        <field name="name">Math 101</field>
        <field name="code">MATH101</field>
        <field name="teacher_id" ref="teacher_jane"/>
        <field name="seats">25</field>
    </record>

    <record id="student_john" model="school.student">
        <field name="name">John Carter</field>
        <field name="email">john.carter@example.com</field>
    </record>

    <record id="enrollment_john_math" model="school.enrollment">
        <field name="student_id" ref="student_john"/>
        <field name="course_id" ref="course_math_101"/>
        <field name="state">enrolled</field>
    </record>
</odoo>
